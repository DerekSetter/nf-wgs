/*
========================================================================================
    Process-specific resource configuration
========================================================================================
*/

process {

    // Default settings for all processes
    cpus   = 2
    memory = '8.GB'
    time   = '4.h'

    withName: 'FASTQC' {
        cpus   = 4
        memory = '8.GB'
        time   = '2.h'
        container = 'biocontainers/fastqc:v0.11.9_cv8'
    }

    withName: 'FASTP' {
        cpus   = 8
        memory = '16.GB'
        time   = '4.h'
        container = 'biocontainers/fastp:v0.20.1_cv1'
    }

    withName: 'BWA_MEM' {
        cpus   = 16
        memory = '32.GB'
        time   = '24.h'
        container = 'biocontainers/bwa-mem2:2.2.1_cv1'
    }

    withName: 'SAMTOOLS_SORT' {
        cpus   = 8
        memory = '16.GB'
        time   = '4.h'
        container = 'biocontainers/samtools:1.17'
    }

    withName: 'MARK_DUPLICATES' {
        cpus   = 4
        memory = '32.GB'
        time   = '8.h'
        container = 'broadinstitute/gatk:4.4.0.0'
    }

    withName: 'BASE_RECALIBRATOR' {
        cpus   = 4
        memory = '16.GB'
        time   = '8.h'
        container = 'broadinstitute/gatk:4.4.0.0'
    }

    withName: 'APPLY_BQSR' {
        cpus   = 4
        memory = '16.GB'
        time   = '4.h'
        container = 'broadinstitute/gatk:4.4.0.0'
    }

    withName: 'HAPLOTYPECALLER' {
        cpus   = 8
        memory = '32.GB'
        time   = '48.h'
        container = 'broadinstitute/gatk:4.4.0.0'
    }

    withName: 'GENOTYPE_GVCFS' {
        cpus   = 8
        memory = '32.GB'
        time   = '24.h'
        container = 'broadinstitute/gatk:4.4.0.0'
    }

    withName: 'VARIANT_FILTRATION' {
        cpus   = 4
        memory = '16.GB'
        time   = '4.h'
        container = 'broadinstitute/gatk:4.4.0.0'
    }

}
