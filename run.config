/*
  Example local run configuration for the mini E. coli dataset.
  This file is for demonstration only and does not change profile behavior.
*/

params {
  input   = "${projectDir}/test/mini_ecoli/samplesheet.csv"
  genome  = "${projectDir}/test/mini_ecoli/ref/ecoli_k12_mg1655.fa"
  outdir  = "${projectDir}/test_results_mini_ecoli_config_example"
  vcf_prefix = "ecoli_mini"
  skip_trimming = false
}
