/*
========================================================================================
    nf-wgs Nextflow Configuration
========================================================================================
    Main configuration file. Includes process-specific resource settings from
    conf/processes.config.
----------------------------------------------------------------------------------------
*/

// Include process-specific resource configuration
includeConfig 'conf/processes.config'

// Default parameters
params {

    // Input/output
    input           = null        // Path to samplesheet CSV (sample_id, fastq_1, fastq_2)
    outdir          = 'results'   // Output directory

    // Reference genome
    genome          = null        // Path to reference genome FASTA
    genome_index    = null        // BWA-MEM2 index prefix (defaults to genome path)

    // Alignment
    mapq_filter     = 1           // samtools view -q threshold before variant calling

    // fastp trimming options
    fastp_cut_window_size  = 4
    fastp_cut_mean_quality = 20

    // Joint FreeBayes options (Alex-style defaults)
    freebayes_region_size          = 100000000
    freebayes_parallel_chunks      = 8
    freebayes_limit_coverage       = 250
    freebayes_use_best_n_alleles   = 8
    freebayes_ploidy               = 2
    freebayes_haplotype_length     = -1

    // Maximum memory/cpus for a single process (used as upper bound)
    max_memory      = '128.GB'
    max_cpus        = 32
    max_time        = '240.h'

}

// Publish outputs to per-process subdirectories named after the process
process {
    publishDir = [
        path:    { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode:    'copy',
        saveAs:  { filename -> filename.equals('versions.yml') ? null : filename }
    ]
}

// Enable DSL2
nextflow.enable.dsl = 2

// Docker/Singularity/Apptainer settings
docker {
    enabled    = false
    runOptions = '-u $(id -u):$(id -g)'
}

singularity {
    enabled    = false
    autoMounts = true
}

apptainer {
    enabled      = false
    autoMounts   = true
    cacheDir     = "${projectDir}/.apptainer"
}

// Pipeline profiles
profiles {

    docker {
        docker.enabled      = true
        singularity.enabled = false
        apptainer.enabled   = false
    }

    singularity {
        singularity.enabled = true
        docker.enabled      = false
        apptainer.enabled   = false
    }

    apptainer {
        apptainer.enabled   = true
        singularity.enabled = false
        docker.enabled      = false
    }

    hpc_apptainer_fullpath {
        apptainer.enabled   = true
        singularity.enabled = false
        docker.enabled      = false
        env.PATH            = "${System.getenv('HOME')}/software/bin:${System.getenv('PATH')}"
    }

    test {
        params.input  = "${projectDir}/test/samplesheet.csv"
        params.outdir = 'test_results'
    }

    mini_ecoli {
        params.input           = "${projectDir}/test/mini_ecoli/samplesheet.csv"
        params.outdir          = 'test_results_mini_ecoli'
        params.genome          = "${projectDir}/test/mini_ecoli/ref/ecoli_k12_mg1655.fa"
        params.genome_index    = "${projectDir}/test/mini_ecoli/ref/ecoli_k12_mg1655.fa"
    }

}

// Manifest
manifest {
    name            = 'nf-wgs'
    author          = 'nf-wgs contributors'
    description     = 'Nextflow pipeline for whole-genome sequence data processing'
    nextflowVersion = '>=23.04.0'
    version         = '1.0.0'
}
